// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum InvoiceStatus {
  DRAFT
  PENDING
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum Currency {
  USD
  EUR
  GBP
  CAD
  AUD
  PKR
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  email         String    @unique
  name          String?
  password      String?   // Hashed password (optional for OAuth)
  image         String?
  role          UserRole  @default(MEMBER)
  companyId     String    @db.ObjectId
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // OAuth fields
  emailVerified DateTime?
  accounts      Account[]
  sessions      Session[]
  
  @@index([companyId])
}

// prisma/schema.prisma

model Company {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  logo          String?   // URL to logo image
  currency      Currency  @default(USD)
  country       String?   // <-- ADD THIS FIELD
  taxRate       Float?    // Default tax rate for this company
  address       String?
  phone         String?
  website       String?
  
  // Relations
  users         User[]
  clients       Client[]
  invoices      Invoice[]
  settings      CompanySettings?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@unique([name])
}

model CompanySettings {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  companyId     String    @unique @db.ObjectId
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoicePrefix String    @default("INV-")
  invoiceNumber Int       @default(1000)
  paymentTerms  Int       @default(30) // Days
  timezone      String    @default("UTC")
  dateFormat    String    @default("MM/DD/YYYY")
}

model Client {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  companyId     String    @db.ObjectId
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  name          String
  email         String
  phone         String?
  address       String?
  taxId         String?
  website       String?
  notes         String?
  
  // Financial
  totalSpent    Float     @default(0)
  totalInvoices Int       @default(0)
  
  invoices      Invoice[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@unique([companyId, email])
  @@index([companyId])
}

model Invoice {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  companyId     String    @db.ObjectId
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  clientId      String    @db.ObjectId
  client        Client    @relation(fields: [clientId], references: [id])
  
  invoiceNumber String    @unique
  issueDate     DateTime  @default(now())
  dueDate       DateTime
  status        InvoiceStatus @default(DRAFT)
  
  // Line items (embedded)
  items         Json      // Array of invoice items
  
  // Financials (calculated server-side)
  subtotal      Float
  taxRate       Float     @default(0)
  taxAmount     Float     @default(0)
  total         Float
  amountPaid    Float     @default(0)
  balanceDue    Float
  
  notes         String?
  terms         String?
  
  // Payment tracking
  paymentDate   DateTime?
  paymentMethod String?
  paymentReference String?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([companyId, clientId])
  @@index([companyId, status])
}

// NextAuth.js models (if using NextAuth)
model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ✅ FIXED: Added @id field for MongoDB compatibility
model VerificationToken {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier   String
  token        String   @unique
  expires      DateTime

  @@unique([identifier, token])
}